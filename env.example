# SEO Audit Dashboard — Environment Variables
# Copia este ficheiro para .env e preenche os valores reais
# NUNCA commits o ficheiro .env — está no .gitignore

# ── Anthropic API ─────────────────────────────────────────────
# Obtém em: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudflare Worker ─────────────────────────────────────────
# URL do teu Worker proxy (substitui o chamado directo à API Anthropic)
WORKER_URL=https://seo-audit-proxy.SEU_SUBDOMINIO.workers.dev

# ── Supabase (opcional) ───────────────────────────────────────
# Para guardar auditorias na cloud
# Obtém em: https://supabase.com → Settings → API
SUPABASE_URL=https://XXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Dashboard ─────────────────────────────────────────────────
# URL pública do dashboard (usado para CORS no Worker)
DASHBOARD_URL=https://pintofbmiguel-bit.github.io/seo-audit-dashboard
